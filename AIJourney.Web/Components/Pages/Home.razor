@page "/"
@rendermode InteractiveServer

<PageTitle>AI Journey Chat</PageTitle>

<div class="chat-app">
    <aside class="history-panel" aria-label="Chat history">
        <div class="profile">
            <div class="avatar" aria-hidden="true">@UserInitials</div>
            <div>
                <div class="profile-name">@CurrentUserName</div>
                <div class="profile-status">AI Journey</div>
            </div>
        </div>

        <button class="new-chat-button" type="button">New chat</button>

        <div class="history-list">
            @foreach (var chat in ChatHistory)
            {
                <button class="history-item" type="button">
                    <span class="history-title">@chat.Title</span>
                    <span class="history-preview">@chat.Preview</span>
                </button>
            }
        </div>
    </aside>

    <section class="start-panel" aria-label="Start a chat">
        <div class="start-content">
            <p class="timestamp">@CurrentTimestamp</p>
            <h1>Good evening @CurrentUserName</h1>

            <EditForm Model="this" OnSubmit="StartConversation" class="start-composer">
                <InputTextArea @bind-Value="DraftMessage"
                               class="start-input"
                               placeholder="Lets start our conversation"
                               rows="3" />
                <button class="start-send-button" type="submit" disabled="@string.IsNullOrWhiteSpace(DraftMessage)">Send</button>
            </EditForm>

            <div class="starter-actions" aria-label="Starter prompts">
                @foreach (var prompt in StarterPrompts)
                {
                    <button class="starter-button" type="button" @onclick="() => UseStarterPrompt(prompt)">
                        @prompt
                    </button>
                }
            </div>
        </div>
    </section>
</div>

@code {
    private string DraftMessage { get; set; } = string.Empty;

    private string CurrentUserName { get; } = Environment.UserName;

    private string CurrentTimestamp { get; } = DateTime.Now.ToString("dddd, MMMM d, yyyy h:mm tt");

    private string UserInitials => string.Join(
        string.Empty,
        CurrentUserName
            .Split([' ', '.', '_', '-'], StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0])));

    private List<ChatHistoryItem> ChatHistory { get; } =
    [
        new("Planning the first lesson", "Structure the AI learning path"),
        new("Prompt ideas", "Draft examples for practice"),
        new("Model comparison", "Notes on quality and latency"),
        new("Next milestones", "Weekly goals and checkpoints")
    ];

    private List<string> StarterPrompts { get; } =
    [
        "Explain a concept",
        "Help me build a project",
        "Plan my AI learning Path"
    ];

    private void UseStarterPrompt(string prompt)
    {
        DraftMessage = prompt;
    }

    private void StartConversation()
    {
        DraftMessage = DraftMessage.Trim();
    }

    private sealed record ChatHistoryItem(string Title, string Preview);
}
