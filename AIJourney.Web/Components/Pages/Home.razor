@page "/"
@rendermode InteractiveServer

<PageTitle>AI Journey Chat</PageTitle>

<div class="chat-app">
    <aside class="history-panel" aria-label="Chat history">
        <div class="profile">
            <div class="avatar" aria-hidden="true">AJ</div>
            <div>
                <div class="profile-name">Alex Johnson</div>
                <div class="profile-status">AI Journey</div>
            </div>
        </div>

        <button class="new-chat-button" type="button">New chat</button>

        <div class="history-list">
            @foreach (var chat in ChatHistory)
            {
                <button class="history-item @(chat.IsActive ? "active" : null)" type="button">
                    <span class="history-title">@chat.Title</span>
                    <span class="history-preview">@chat.Preview</span>
                </button>
            }
        </div>
    </aside>

    <section class="conversation-panel" aria-label="Chat conversation">
        <header class="conversation-header">
            <div>
                <h1>AI Journey</h1>
                <p>Text chat with your model</p>
            </div>
            <span class="model-badge">Model ready</span>
        </header>

        <div class="message-list">
            @foreach (var message in Messages)
            {
                <article class="message @message.Role">
                    <div class="message-author">@message.Author</div>
                    <div class="message-bubble">@message.Text</div>
                </article>
            }
        </div>

        <EditForm Model="this" OnSubmit="SendMessage" class="composer">
            <InputTextArea @bind-Value="DraftMessage"
                           class="composer-input"
                           placeholder="Type a message..."
                           rows="1" />
            <button class="send-button" type="submit" disabled="@string.IsNullOrWhiteSpace(DraftMessage)">Send</button>
        </EditForm>
    </section>
</div>

@code {
    private string DraftMessage { get; set; } = string.Empty;

    private List<ChatHistoryItem> ChatHistory { get; } =
    [
        new("Planning the first lesson", "Structure the AI learning path", true),
        new("Prompt ideas", "Draft examples for practice"),
        new("Model comparison", "Notes on quality and latency"),
        new("Next milestones", "Weekly goals and checkpoints")
    ];

    private List<ChatMessage> Messages { get; } =
    [
        new("assistant", "AI Model", "Hi Alex. What would you like to explore today?"),
        new("user", "You", "Help me plan a simple learning path for AI fundamentals."),
        new("assistant", "AI Model", "Start with core concepts, then practice with small prompts, evaluations, and one small app.")
    ];

    private void SendMessage()
    {
        var text = DraftMessage.Trim();

        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        Messages.Add(new ChatMessage("user", "You", text));
        Messages.Add(new ChatMessage("assistant", "AI Model", "This is where the model response will appear once the backend is connected."));
        DraftMessage = string.Empty;
    }

    private sealed record ChatHistoryItem(string Title, string Preview, bool IsActive = false);

    private sealed record ChatMessage(string Role, string Author, string Text);
}
